# .env — NotionCanvas MCP credentials
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.

# ── Notion ──────────────────────────────────────────────────────────────────
# Get from: notion.com → Settings → Connections → Develop integrations → New integration (Internal)
# Share each target Notion page with this integration before use.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic ───────────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Figma ───────────────────────────────────────────────────────────────────
# Get from: figma.com → Settings → Security → Personal access tokens → Generate new token
# Required scopes: file_content:read, file_metadata:read
# Max expiry: 90 days. Server warns 14 days before expiry.
FIGMA_ACCESS_TOKEN=figd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIGMA_PAT_EXPIRES=2026-06-25

# ── Server config (optional) ─────────────────────────────────────────────────
WS_PORT=9223
LOG_LEVEL=info
